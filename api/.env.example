# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://ecom_user:ecom_pass@localhost:5432/ecommerce_db

# ── Cache / Sessions (Redis) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the two front-ends
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── JWT ───────────────────────────────────────────────────────────────────────
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Email ─────────────────────────────────────────────────────────────────────
# Use 'console' for dev, 'smtp' for prod
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_ENDPOINT_SECRET=whsec_replace_me

# ── AWS S3 (only needed in production) ───────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=
